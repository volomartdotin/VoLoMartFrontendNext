# VoLoMart vendor site

# Backend API base URL — used for service list, pricing plans, and image proxy
NEXT_PUBLIC_API_URL=https://back.volomart.in

# Public site URL — used in sitemap, SEO, canonical links
NEXT_PUBLIC_SITE_URL=https://www.volomart.in

# App store deep-link redirects (optional overrides)
# NEXT_PUBLIC_PLAY_STORE_URL=https://play.google.com/store/apps/details?id=com.volomart.app
# NEXT_PUBLIC_APP_STORE_URL=https://apps.apple.com/app/id0000000000

# --- S3 deploy (npm run deploy:s3) — read from .env; AWS keys via `aws configure` ---
# S3_BUCKET=your-website-bucket-name
# CLOUDFRONT_DISTRIBUTION_ID=
# AWS_REGION=ap-south-1
